<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" spacing="30.0" stylesheets="@mainmenu.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="LoginController">
   <children>
      <Label alignment="TOP_CENTER" text="Login/Register" textAlignment="CENTER">
         <font>
            <Font name="Forte" size="49.0" />
         </font>
         <opaqueInsets>
            <Insets top="-50.0" />
         </opaqueInsets>
         <VBox.margin>
            <Insets top="-50.0" />
         </VBox.margin>
      </Label>
      <Label text="Username:">
         <font>
            <Font name="Georgia" size="15.0" />
         </font>
         <padding>
            <Insets bottom="-30.0" />
         </padding>
      </Label>
      <TextField fx:id="usernameField" alignment="CENTER" maxWidth="200.0" promptText="Enter Username:">
         <cursor>
            <Cursor fx:constant="TEXT" />
         </cursor>
      </TextField>
      <Label text="Password:">
         <font>
            <Font size="15.0" />
         </font>
         <padding>
            <Insets bottom="-30.0" />
         </padding>
      </Label>
      <PasswordField fx:id="passwordField" alignment="CENTER" maxWidth="200.0" prefHeight="26.0" prefWidth="532.0" promptText="Enter Password:">
         <cursor>
            <Cursor fx:constant="TEXT" />
         </cursor>
      </PasswordField>
      <Button mnemonicParsing="false" onAction="#onLogin" prefHeight="38.0" prefWidth="154.0" text="Login" textAlignment="CENTER" fx:id="loginButton">
         <font>
            <Font size="33.0" />
         </font>
      </Button>
      <Button mnemonicParsing="false" onAction="#onSignup" prefHeight="32.0" prefWidth="154.0" text="Sign Up" />
      <Label fx:id="statusLabel" text="Enter details to login or sign up" />
   </children>
</VBox>
